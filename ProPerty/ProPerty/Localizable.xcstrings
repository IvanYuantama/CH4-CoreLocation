    "overview_backend_template" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This area is classified as %1$@ with a %2$@ temperature profile (currently %3$@). Air quality is %4$@ (AQI %5$@), green space is %6$@, and the terrain is %7$@. Nearest access is a %8$@, there are %9$@ public facilities around, and roughly %10$@ residents live here."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kawasan ini tergolong %1$@ dengan profil suhu %2$@ (saat ini %3$@). Kualitas udara %4$@ (AQI %5$@), ruang hijau %6$@, dan berada di %7$@. Akses terdekat berupa %8$@, terdapat %9$@ fasilitas umum di sekitar, dan dihuni sekitar %10$@ jiwa."
          }
        }
      }
    },
    "overview_template" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This area offers good accessibility with major roads nearby and %@ public facilities within 2 km. Water quality is moderate (%@/100), while air quality is %@ (AQI %@). The elevation is %@ m above sea level with an average temperature of %@°C. A %@ crime rate and %@%% green space support a comfortable environment."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Area ini punya aksesibilitas baik dengan jalan utama di dekatnya dan %@ fasilitas umum dalam radius 2 km. Kualitas air sedang (%@/100), kualitas udara %@ (AQI %@). Elevasi %@ m di atas permukaan laut dengan suhu rata-rata %@°C. Tingkat kriminalitas %@ dan %@%% ruang hijau mendukung lingkungan yang nyaman."
          }
        }
      }
    },
